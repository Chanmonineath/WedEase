NODE_ENV=development
PORT=5000
# MongoDB Atlas connection string (recommended)
ATLAS_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority

# Optional local MongoDB connection string
# MONGODB_URI=mongodb://127.0.0.1:27017/wedease

DB_NAME=WedEase
JWT_SECRET=replace_with_your_secure_secret
CORS_ORIGIN=http://localhost:5500
